{
  "name": "ml-path-finding-robot",
  "version": "0.1.0",
  "private": true,
  "description": "A browser playground that simulates a two-wheeled, bit:bot-style robot following a coloured path on an A2 surface.",
  "type": "module",
  "packageManager": "pnpm@9.7.0",
  "scripts": {
    "gen:paths": "node image-gen/generate.ts",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.65",
    "@types/node": "^22.5.0",
    "typescript": "^5.6.0",
    "vite": "^6.4.3"
  }
}
